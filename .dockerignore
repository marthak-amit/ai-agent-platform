# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore

# ── Backend ───────────────────────────────────────────────────────────────────
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/.pytest_cache/
backend/.ruff_cache/
backend/.env
backend/.env.local
backend/tests/
backend/dist/
backend/build/
backend/*.egg-info/

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/**/*.log

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
