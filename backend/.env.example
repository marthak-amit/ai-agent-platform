# ─────────────────────────────────────────────────────────────────
# AI Agent Platform — Environment Variables
#
# Copy this file to .env and fill in real values before running.
# Never commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# asyncpg driver is added automatically; write plain postgresql:// here.
DATABASE_URL=postgresql://user:password@localhost:5432/ai_agent_db

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key — no longer used, kept for reference
GEMINI_API_KEY=

# Meta / WhatsApp Cloud API — Meta Developer Console → App → WhatsApp → Configuration
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Instagram (optional — only needed for Growth / Pro plan features)
INSTAGRAM_ACCESS_TOKEN=

# Razorpay (optional — only needed for payment features)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# JWT signing secret — use a long random string in production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Admin panel key — sent as X-Admin-Key header to /admin/* endpoints
ADMIN_SECRET_KEY=change-me-admin-secret
